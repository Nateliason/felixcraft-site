{
  "functions": {
    "api/stripe-webhook.js": {
      "maxDuration": 10
    },
    "api/verify-crypto.js": {
      "maxDuration": 15
    },
    "api/dashboard-data.js": {
      "maxDuration": 15
    },
    "api/refresh-revenue-cache.js": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/refresh-revenue-cache",
      "schedule": "0 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/dl/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/token",
      "destination": "https://www.clanker.world/clanker/0xf30Bf00edd0C22db54C9274B90D2A4C21FC09b07",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/stripe-webhook",
      "destination": "/api/stripe-webhook.js"
    },
    {
      "source": "/api/verify-crypto",
      "destination": "/api/verify-crypto.js"
    },
    {
      "source": "/api/dashboard-data",
      "destination": "/api/dashboard-data.js"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    }
  ]
}
